# Health check endpoint for Caddy itself
:8080 {
    respond /health 200 {
        body "Caddy frontend proxy is healthy"
    }
}

# Redirect www to non-www (optional)
www.your-frontend-domain.com {
    redir https://your-frontend-domain.com{uri} permanent
}