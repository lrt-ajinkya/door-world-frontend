# Caddyfile for Door World Frontend
# Place this file at /etc/caddy/Caddyfile on your server

# Frontend application - Replace with your domain
your-frontend-domain.com {
    # Reverse proxy to frontend container
    reverse_proxy localhost:3000 {
        # Headers for better security
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    
    # Security headers
    header {
        # Enable HSTS
        Strict-Transport-Security max-age=31536000;
        
        # Prevent MIME sniffing
        X-Content-Type-Options nosniff
        
        # Enable XSS protection
        X-XSS-Protection "1; mode=block"
        
        # Prevent clickjacking for most cases, but allow same origin for React
        X-Frame-Options SAMEORIGIN
        
        # Content Security Policy for React app
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://46.62.155.60;"
        
        # Remove server information
        -Server
    }
    
    # Rate limiting for frontend
    rate_limit {
        zone frontend {
            key {remote_host}
            events 200
            window 1m
        }
    }
    
    # Gzip compression
    encode gzip
    
    # Cache static assets (served by nginx in container, but add extra caching layer)
    @static {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
    }
    header @static {
        Cache-Control "public, max-age=31536000, immutable"
    }
    
    # Logging
    log {
        output file /var/log/caddy/doorworld-frontend-access.log
        format json
    }
}

# API Backend (if you want to serve both through Caddy)
api.your-domain.com {
    # Reverse proxy to backend container
    reverse_proxy localhost:3420 {
        # Health check
        health_uri /health
        health_interval 30s
        health_timeout 5s
        
        # Headers for API
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    
    # CORS headers for API
    @cors_preflight {
        method OPTIONS
    }
    respond @cors_preflight 200 {
        close
    }
    
    header {
        # CORS headers
        Access-Control-Allow-Origin https://your-frontend-domain.com
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
        Access-Control-Max-Age 86400
        
        # Security headers for API
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        -Server
    }
    
    # Rate limiting for API
    rate_limit {
        zone api {
            key {remote_host}
            events 100
            window 1m
        }
    }
    
    # Logging
    log {
        output file /var/log/caddy/doorworld-api-access.log
        format json
    }
}

# Alternative: If you want to serve both frontend and API on the same domain
